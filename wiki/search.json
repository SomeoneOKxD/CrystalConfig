---
layout: null
permalink: /search.json
---
[
  {%- assign searchable_pages = site.pages | where_exp: "item", "item.layout == 'default'" | sort: "url" -%}
  {%- for item in searchable_pages -%}
    {
      "title": {{ item.title | default: site.title | jsonify }},
      "description": {{ item.description | default: "" | jsonify }},
      "url": {{ item.url | relative_url | jsonify }},
      "content": {{ item.content | markdownify | strip_html | replace: "\n", " " | replace: "\r", " " | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
]
